@page "/feedback"
@layout MainLayout
@using FlowAISystem.Data.DTOs.Feedback
@using FlowAISystem.Data.DTOs.Prediction
@using FlowAISystem.Core.Services
@inject IPredictionService PredictionService
@inject IFeedbackService FeedbackService

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h3> Feedback </h3>
        <button class="btn btn-primary"
                @onclick="ShowAddForm">
             Add Feedback
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (showForm)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5>Add Feedback</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Prediction</label>
                        <select class="form-control"
                                @bind="newFeedback.PredictionId">
                            <option value="0">Select Prediction...</option>
                            @foreach (var p in predictions)
                            {
                                <option value="@p.Id">
                                    @p.StudentName — @p.SubjectName (@p.Result)
                                </option>
                            }
                        </select>
                    </div>
                  
                    <div class="mb-3">
                      <label class="form-label fw-bold">Is Correct?</label>
                      <div>
                      <div class="form-check form-check-inline">
                    <input class="form-check-input" 
                        type="radio" 
                        name="isCorrect"
                        checked="@(newFeedback.IsCorrect == true)"
                        @onchange="() => newFeedback.IsCorrect = true" />
                    <label class="form-check-label"> Correct</label>
                   </div>
                    <div class="form-check form-check-inline">
                       <input class="form-check-input" 
                             type="radio" 
                              name="isCorrect"
                             checked="@(newFeedback.IsCorrect == false)"
                           @onchange="() => newFeedback.IsCorrect = false" />
                       <label class="form-check-label"> Incorrect</label>
                      </div>
                     </div>
                    </div>
                     <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Correction (optional)</label>
                        <textarea class="form-control"
                                  @bind="newFeedback.Correction"
                                  rows="3"
                                  placeholder="Enter correction if incorrect...">
                        </textarea>
                    </div>
                </div>
                <button class="btn btn-success me-2"
                        @onclick="HandleCreate">
                     Save
                </button>
                <button class="btn btn-secondary"
                        @onclick="HideAddForm">
                    Cancel
                </button>
            </div>
        </div>
    }

    @* Feedback Table *@
    @if (feedbacks == null)
    {
        <p>Loading...</p>
    }
    else if (!feedbacks.Any())
    {
        <p>No feedback yet.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Prediction</th>
                    <th>Is Correct</th>
                    <th>Correction</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in feedbacks)
                {
                    <tr>
                        <td>@f.Id</td>
                        <td>@f.PredictionId</td>
                        <td>
                            @if (f.IsCorrect)
                            {
                                <span class="badge bg-success"> Correct</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"> Incorrect</span>
                            }
                        </td>
                        <td>@f.Correction</td>
                        <td>@f.CreatedAt.ToString("dd-MM-yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>
@code {
    private List<FeedbackResponseDto>feedbacks = new ();
    private List<PredictionResponseDto> predictions = new();
    private FeedbackCreateDto newFeedback = new(); 
    private string errorMessage = "";
    private string successMessage = "";
    private bool showForm = false;

    protected override async Task OnInitializedAsync() {
        
      await LoadData();
    }

    private async Task LoadData() {
        try {
            feedbacks = await FeedbackService.GetAllAsync();
            predictions = await PredictionService.GetAllAsync();
        } catch (Exception ex) {
            errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private async Task ShowAddForm() {
        showForm = true;
        newFeedback = new ();
        errorMessage = "";
        successMessage = "";
    }

    private async Task HideAddForm() {
        showForm = false;
        newFeedback = new ();
      
    }

    private async Task HandleCreate() {
     
      
        try {
            await FeedbackService.CreateAsync(newFeedback);
            successMessage = "Feedback submitted successfully!";
            errorMessage = "";
            showForm = false;
            await LoadData();
        } catch (Exception ex) {
            errorMessage = $"Error submitting feedback: {ex.Message}";
            successMessage = "";
        }
    }
}