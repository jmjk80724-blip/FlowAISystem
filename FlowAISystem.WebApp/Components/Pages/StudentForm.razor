@page "/students/add"
@page "/students/edit/{Id:int}"
@rendermode InteractiveServer
@using FlowAISystem.Core.Services
@using FlowAISystem.Core.Services.Interface
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@inject NavigationManager Navigation
@inject IStudentService StudentService

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@(Id ==null ? "Add Student": "Edit Student")</h4>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(errorMessage)) {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input class="form-control" @bind="student.FullName" placeholder="Enter full name" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input class="form-control" @bind="student.Email" placeholder="Entet email" disabled="@(Id !=null)" />
                </div>
                  <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Date of Birth</label>
                    <input class="form-control" @bind="student.DateOfBirth" @bind:format="yyyy-MM-dd" />
               </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Gender</label>
                    <select class="form-control" @bind="student.Gender">
                        <option value="">Select...</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                 <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Phone</label>
                    <input class="form-control" @bind="student.PhoneNumber" placeholder="Entet phone" />
                </div>
        </div>
        <div class="mt-3">
            <button class="btn btn-success me-2"@onclick="HandleSubmit">Save</button>
            <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </div>

    </div>
</div>
</div>

@code {
    [Parameter] public int?  Id {get ; set;}   
    private StudentCreateDto student = new() {DateOfBirth = DateTime.Today};
    private string errorMessage = "";

    protected override async Task OnInitializedAsync() {
      if (Id!=null) {
        try {
            var existring = await StudentService.GetByIdAsync(Id.Value);
            if(existring != null) {
                student.FullName = existring.FullName;
                student.Email = existring.Email;
                student.Gender = existring.Gender;
                student.PhoneNumber = existring.PhoneNumber;
                student.DateOfBirth = existring.DateOfBirth;
            }
        }
        catch (Exception ex) {
            errorMessage = ex.Message;
        }
      }
    }

    private async Task HandleSubmit() {
        if (string.IsNullOrWhiteSpace(student.FullName)) {
            errorMessage = "Plear Entered student name!";
            return;
        }

        try{
            if(Id == null) {
                await StudentService.CreateAsync(student);
            }
            else
            {
                var updateDto = new StudentUpdateDto {
                    FullName =student.FullName,
                    Gender = student.Gender,
                    PhoneNumber = student.PhoneNumber
                };
                 await StudentService.UpdateAsync(Id.Value, updateDto);
            }
            Navigation.NavigateTo("/students");
        }
        catch (Exception ex) {
            errorMessage = ex.Message;
        }
    }
    private void Cancel() {
        Navigation.NavigateTo("/students");
    }
}