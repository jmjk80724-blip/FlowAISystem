@page "/students"
@layout MainLayout
@rendermode InteractiveServer
@using FlowAISystem.Core.Services
@using FlowAISystem.Core.Services.Interfaces
@using FlowAISystem.Data.Entities
@inject IStudentService StudentService

<div clas="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h3> Students </h3>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            Add Student
        </button>
    </div>

    @* Error Message *@
    @if (!string.IsNullOrEmpty(errorMessage)){
        <div class="alert-danger alert-dismissible fade show">
            @errorMessage
        </div>
    }

    @* Success Message *@ 
    @if (!string.IsNullOrEmpty(successMessage)) {
        <div class="alert alert-success alert-dismissible fade show">
            @successMessage
        </div>
    }
   @* Add Form *@
    @if (showForm)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Add New Student</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input class="form-control" @bind="newStudent.FullName" placeholder="Enter full name" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" class="form-control" @bind="newStudent.Email" placeholder="Enter email" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Date of Birth</label>
                        @*  Add Date of Birth  *@
                        <input type="date" class="form-control" @bind="newStudent.DateOfBirth" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Gender</label>
                        <select class="form-control" @bind="newStudent.Gender">
                            <option value="">Select...</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Phone</label>
                        <input class="form-control" @bind="newStudent.PhoneNumber" placeholder="Enter phone" />
                    </div>
                </div>
                <div class="mt-2">
                    <button class="btn btn-success me-2" @onclick="HandleCreate">Save</button>
                    <button class="btn btn-secondary" @onclick="HideForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @*Students Table *@
    @if (students ==null)
    {
        <div class="text-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading students...</p>
        </div>
    }
    else if (!students.Any()) 
    {
      <div class="alert alert-info text-conter">No Student found in the system.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-primary">
                    <try>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Gender</th>
                        <th>Phone</th>
                        <th class="text-center">Action</th>
                    </try>
                </thead>
                <tbody>
                    @foreach (var s in students) {
                        <tr>
                            <td>@s.Id</td>
                            <td>@s.FullName</td>
                            <td>@s.Email</td>
                            <td>@s.Gender</td>
                            <td>@s.PhoneNumber</td>
                            <td class="text-cemter">
                                @*  *@
                                <button class="btn btn-danger btn-sm" @onclick="() => HandleDelete(s.Id, s.FullName)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


@code {
    private List<StudentResponseDto> students = null;
    private StudentCreateDto newStudent=new();
    private string errorMessage="";
    private string successMessage= "";
    private bool showForm =false;

    protected override async Task OnInitializedAsync() {
        await LoadStudents();
    }
    
    private async Task LoadStudents() {
        try{
            students = await StudentService.GetAllAsync();
        }
        catch(Exception ex) {
          errorMessage = $"Unable to fetch data : {ex.Message}";
        }
    }
    private void ShowAddForm() {
        showForm = true;
        newStudent = new(){DateOfBirth = DateTime.Today};
        ClearMessages();
    }

    private void HideForm() {
        showForm = false;
        newStudent = new();
        ClearMessages();
    }

    private async Task HandleCreate() {
        if(string.IsNullOrWhiteSpace(newStudent.FullName)) {
            errorMessage = "Please, Enter Student Name!";
            return;
        }
        try {
            ClearMessages();
            await StudentService.CreateAsync(newStudent);
            successMessage = $"Added Student'{newStudent.FullName}' successful!";
            showForm = false;
            await LoadStudents();
        }
        catch (Exception ex) {
            errorMessage= $"There was an error saving: {ex.Message}";

        }
    }
    private async Task HandleDelete(int id, string name) {
        errorMessage ="";
        successMessage = "";

        try{
            await StudentService.DeleteAsync(id);
            successMessage= $"Student data deleted '{name} successful!";
            await LoadStudents();
        }
        catch (Exception ex) {
            errorMessage = $"Can not deleted: {ex.Message}";
        }
    }
    

    private void ClearMessages() {
      errorMessage = "";
      successMessage = "";
    }

}